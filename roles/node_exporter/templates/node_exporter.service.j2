[Unit]
Description=Prometheus Node Exporter
Documentation=https://github.com/prometheus/node_exporter
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User={{ node_exporter_user }}
Group={{ node_exporter_group }}
SupplementaryGroups=systemd-journal
ExecStart={{ node_exporter_install_dir }}/node_exporter \
  --web.listen-address={{ node_exporter_listen_address }} \
  --collector.textfile.directory={{ node_exporter_textfile_dir }}{% for collector in node_exporter_enabled_collectors %} \
  --collector.{{ collector }}{% endfor %}{% for collector in node_exporter_disabled_collectors %} \
  --no-collector.{{ collector }}{% endfor %}{% if node_exporter_extra_args | length > 0 %} \
  {{ node_exporter_extra_args }}{% endif %}
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
